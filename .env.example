# Provara Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Master Encryption Key (REQUIRED for API key storage)
# ──────────────────────────────────────────────
# Used to encrypt provider API keys at rest with AES-256-GCM.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVARA_MASTER_KEY=

# ──────────────────────────────────────────────
# Provider API Keys (OPTIONAL)
# ──────────────────────────────────────────────
# You can set these here OR add them through the dashboard at /dashboard/api-keys.
# Dashboard keys (stored encrypted in the DB) take precedence over these.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
ZAI_API_KEY=

# ──────────────────────────────────────────────
# Ollama (OPTIONAL — always enabled)
# ──────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ──────────────────────────────────────────────
# Database (Turso / libSQL)
# ──────────────────────────────────────────────
# Local SQLite file (default):
# DATABASE_URL=file:provara.db
#
# Turso hosted database:
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ──────────────────────────────────────────────
# CORS (RECOMMENDED for production)
# ──────────────────────────────────────────────
# Comma-separated list of origins allowed to make authenticated cross-origin
# requests against the gateway. When unset, the gateway runs in permissive
# mode (any origin with credentials). Always set this on prod deploys.
# Example:
# PROVARA_ALLOWED_ORIGINS=https://www.provara.xyz,https://gateway.provara.xyz

# ──────────────────────────────────────────────
# Service Ports (OPTIONAL)
# ──────────────────────────────────────────────
# PORT=4000           # Gateway
